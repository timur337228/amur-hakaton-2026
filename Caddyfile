:80 {
  encode gzip zstd

  @api path /api/* /health
  handle @api {
    reverse_proxy api:8000
  }

  handle {
    reverse_proxy web:8001
  }
}

www.{$DOMAIN} {
  redir https://{$DOMAIN}{uri} permanent
}

