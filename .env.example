POSTGRES_DB=budget_analytics
POSTGRES_USER=budget_app
POSTGRES_PASSWORD=budget_app_dev
POSTGRES_PORT=5432

PROJECT_FILE_HOST_PATH=./project_file

ALLOW_LOCAL_IMPORT=true
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:8001,http://127.0.0.1:8001

DJANGO_SECRET_KEY=budget-analytics-dev-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
BUDGET_API_BASE_URL=http://localhost:8000

LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=https://api.302.ai/v1/chat/completions
LLM_TIMEOUT_SECONDS=60

WHISPER_PROVIDER=api
WHISPER_API_KEY=
WHISPER_API_BASE_URL=https://api.302.ai/v1/audio/transcriptions
WHISPER_API_MODEL=whisper-v3-turbo
WHISPER_LOCAL_MODEL=large-v3-turbo
WHISPER_LANGUAGE=ru
WHISPER_TEMPERATURE=0
WHISPER_RESPONSE_FORMAT=verbose_json
WHISPER_TIMESTAMP_GRANULARITY=word
WHISPER_DIARIZE=false
WHISPER_TIMEOUT_SECONDS=120
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8
WHISPER_VAD_FILTER=true
